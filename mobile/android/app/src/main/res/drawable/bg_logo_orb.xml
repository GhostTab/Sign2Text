<?xml version="1.0" encoding="utf-8"?>
<!-- Light “glass” disc behind hand logo -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="oval">
            <solid android:color="#F4F0FF" />
        </shape>
    </item>
    <item
        android:bottom="3dp"
        android:left="3dp"
        android:right="3dp"
        android:top="3dp">
        <shape android:shape="oval">
            <gradient
                android:angle="135"
                android:endColor="#FFFFFF"
                android:startColor="#FAF5FF"
                android:type="linear" />
            <stroke
                android:width="1.5dp"
                android:color="@color/logo_ring_stroke" />
        </shape>
    </item>
</layer-list>
