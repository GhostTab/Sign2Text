<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_welcome_soft"
    android:fitsSystemWindows="true"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="end"
        android:paddingStart="20dp"
        android:paddingTop="14dp"
        android:paddingEnd="20dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCredits"
            style="@style/Widget.MaterialComponents.Button"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:contentDescription="@string/cd_show_credits"
            android:backgroundTint="@color/primary"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:padding="0dp"
            android:text="@string/credits_button"
            android:textColor="@color/on_primary"
            android:textSize="18sp"
            app:cornerRadius="20dp"
            app:elevation="0dp"
            app:rippleColor="@color/primary_light" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:overScrollMode="never"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingStart="32dp"
            android:paddingTop="48dp"
            android:paddingEnd="32dp"
            android:paddingBottom="24dp">

            <!-- Hand hero (soft 3D mark + glass disc) -->
            <FrameLayout
                android:layout_width="168dp"
                android:layout_height="168dp"
                android:background="@drawable/bg_logo_orb"
                android:elevation="10dp"
                android:padding="22dp">

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:contentDescription="@string/cd_hand_logo"
                    android:scaleType="fitCenter"
                    android:src="@drawable/asl_logo"
                    tools:ignore="ImageContrastCheck" />
            </FrameLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:letterSpacing="0.1"
                android:text="@string/welcome_brand"
                android:textColor="@color/primary"
                android:textSize="13sp"
                android:textAllCaps="true" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:fontFamily="sans-serif-medium"
                android:gravity="center"
                android:letterSpacing="-0.02"
                android:lineSpacingMultiplier="1.08"
                android:text="@string/welcome_headline"
                android:textColor="@color/text_headline"
                android:textSize="28sp" />

        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="28dp"
        android:paddingEnd="28dp"
        android:paddingBottom="32dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnContinue"
            style="@style/Widget.Sign2Text.Button.Filled"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:paddingStart="20dp"
            android:paddingEnd="16dp"
            android:text="@string/welcome_cta"
            app:cornerRadius="18dp"
            app:icon="@drawable/ic_arrow_forward_cta"
            app:iconGravity="textEnd"
            app:iconPadding="12dp" />
    </LinearLayout>
</LinearLayout>
